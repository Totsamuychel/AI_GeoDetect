# =============================================================================
# .gitignore for geo-photo-ukraine diploma project
# =============================================================================

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
.env
.conda/

# ── Data & Large Files (IMPORTANT) ───────────────────────────────────────────
# Ignore ALL images in any data-related directory
**/images/**/*.jpg
**/images/**/*.jpeg
**/images/**/*.png
**/*.zip

# Specifically ignore raw and processed data images
data/raw/images/
data/processed/images/
dataset/raw/images/
dataset/raw/osv5m/images/
dataset/processed/images/

# Ignore split files if they are huge
dataset/manifests/train.csv
dataset/manifests/val.csv

# Cache
.cache/
data/.cache/

# Keep manifest files
!data/dataset_manifest_example.csv
!dataset/raw/osv5m/manifest.csv
!data/osv5m/manifest.csv

# ── Model checkpoints and weights ─────────────────────────────────────────────
results/checkpoints/
*.pth
*.pt
*.ckpt

# ── Logs & Temporary ──────────────────────────────────────────────────────────
results/logs/
wandb/
mlruns/
*.log
tmp/
temp/

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
